rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: leaderboard
    // Document ID: {entryId}
    // Fields:
    //   - userId: string (required, immutable) - The UID of the user
    //   - username: string (required, max 50 chars) - Display name
    //   - percentage: number (required, 12-99) - The score
    //   - badge: string (required, max 100 chars) - The badge
    //   - description: string (required, max 500 chars) - The daily description
    //   - createdAt: timestamp (required, immutable) - Creation time
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidLeaderboardEntry(data) {
      return hasOnlyAllowedFields(['userId', 'username', 'percentage', 'badge', 'description', 'createdAt']) &&
             data.userId is string && data.userId == request.auth.uid &&
             data.username is string && data.username.size() > 0 && data.username.size() <= 50 &&
             data.percentage is number && data.percentage >= 12 && data.percentage <= 99 &&
             data.badge is string && data.badge.size() > 0 && data.badge.size() <= 100 &&
             data.description is string && data.description.size() > 0 && data.description.size() <= 500 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /leaderboard/{entryId} {
      // Anyone can read the leaderboard
      allow read: if true;
      
      // Only authenticated users can create an entry for themselves
      allow create: if isAuthenticated() && 
                    isValidLeaderboardEntry(request.resource.data);
                    
      // Entries are immutable once created (no updates allowed)
      allow update: if false;
      
      // Users can delete their own entries
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
